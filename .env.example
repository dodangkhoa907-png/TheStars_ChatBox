# Copy this file's contents into your actual environment variables
# (IntelliJ Run Configuration → Environment variables, your shell profile,
# or Render's dashboard → Environment). Spring Boot reads these directly —
# this file itself is never loaded automatically, it's just a reference.

# Required — no default, the app fails to start without it.
DB_PASSWORD=

# Optional — override only if your database isn't the shared dev instance.
DB_URL=jdbc:sqlserver://14.225.217.109;databaseName=ChatBox_TheStars;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa

# Optional — only needed once Google Sign-In is actually wired up.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Render sets PORT automatically; leave unset for local dev (defaults to 8080).
PORT=

# Optional — where uploaded files are stored (defaults to ./uploads, ephemeral on most PaaS).
UPLOAD_DIR=

# Optional — set to INFO or WARN to quiet down logs outside local dev (defaults to DEBUG).
LOG_LEVEL=
